# Copy this file to .env and fill in your own values. Never commit a real .env.

# Required: your provider API key. litellm reads this for the default
# gpt-4o-mini model (OpenAI). If you switch LLM_MODEL to a different
# provider, set that provider's key env var instead (see README).
OPENAI_API_KEY=sk-your-key-here

# Any model string litellm understands, e.g. gpt-4o-mini, gpt-4o,
# claude-3-5-sonnet-20241022, gemini/gemini-1.5-pro, ollama/llama3, etc.
# Swapping providers/models is just changing this one value - no code changes.
LLM_MODEL=gpt-4o-mini

# Path (relative to the backend/ working directory) to the knowledge-base /
# system-prompt file. Point this at a different file to repurpose the bot
# (e.g. data/employee_policy_kb.md for an internal Q&A bot).
SYSTEM_PROMPT_FILE=data/knowledge_base.md

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:5173

# Port uvicorn serves on.
PORT=8000

# ─── Weaviate Vector DB (RAG) ────────────────────────────────────────────────
# Optional. Run `python scripts/upsert_to_weaviate.py` after setting these to
# populate the KB. If left blank, the chatbot falls back to the flat
# knowledge_base.md file.
#
# Self-hosted (default via `docker compose up`, runs the `weaviate` service
# from docker-compose.yml with anonymous access — no API key needed):
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
#
# Or Weaviate Cloud instead — create a free cluster at
# https://console.weaviate.cloud and set both:
# WEAVIATE_URL=https://your-cluster.weaviate.network
# WEAVIATE_API_KEY=your-weaviate-admin-api-key

# ─── bucketlistt MCP (live catalog data) ─────────────────────────────────────
# Optional. Adds live destinations/activities/slots tools from bucketlistt's
# own MCP server (see app/mcp_client.py). Only read-only catalog tools are
# loaded — auth, cart, and payment tools are never exposed to the model.
# If left blank, the chatbot just doesn't get these tools.
MCP_SERVER_URL=https://mcp.bucketlistt.com/mcp
